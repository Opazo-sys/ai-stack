# Configurações Gerais de Rede e Certificado SSL
DOMAIN=your-domain.com
EMAIL=your-email@example.com

# Configurações de Segurança do SearXNG
# (No seu arquivo real .env, altere para uma string aleatória longa)
SEARXNG_SECRET=change_this_to_a_long_random_secret_string

# Ativação do limitador contra bots e bloqueios de IP (true/false)
SEARXNG_LIMITER=true

# URL de conexão com o banco em memória (necessário para o limiter funcionar)
# Altere 'valkey' pelo nome do serviço do banco de dados no seu docker-compose.yml
SEARXNG_VALKEY_URL=valkey://valkey:6379/0
